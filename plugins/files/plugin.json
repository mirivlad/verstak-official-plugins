{
  "schemaVersion": 1,
  "id": "verstak.files",
  "name": "Files",
  "version": "0.1.0",
  "apiVersion": "0.1.0",
  "description": "Deal-scoped vault file explorer with create, rename, trash, filtering, sorting, and Workbench openResource integration.",
  "localization": { "defaultLocale": "en", "locales": { "en": "locales/en.json", "ru": "locales/ru.json" } },
  "source": "official",
  "icon": "folder",
  "provides": [
    "verstak/files/v1"
  ],
  "requires": [
    "verstak/core/files/v1",
    "verstak/core/workbench/v1"
  ],
  "permissions": [
    "files.read",
    "files.write",
    "files.delete",
    "files.openExternal",
    "events.subscribe",
    "workbench.open",
    "ui.register"
  ],
  "frontend": {
    "entry": "frontend/src/index.js"
  },
  "contributes": {
    "workspaceItems": [
      {
        "id": "verstak.files.workspace",
        "title": "Files",
        "icon": "folder",
        "component": "FilesView"
      }
    ]
  }
}
